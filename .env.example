# Cloud sync (optional) — automatic backup of all app data to your own server.
#
# Leave these unset and the app runs local-only (data stays on the device).
# Set both to enable automatic sync. See backend/README.md to stand up the
# server endpoint on your portfolio (free, reusable across apps).
#
# Copy this file to `.env.local` (gitignored) and fill in real values, or set
# them as build-time env vars in your host / CI.

# The deployed store endpoint, e.g. https://your-portfolio.com/api/store
VITE_SYNC_URL=

# The shared secret — must equal SYNC_TOKEN on the server. Make it long+random.
VITE_SYNC_TOKEN=
